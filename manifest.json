{
  "manifest_version": 3,
  "name": "ServiceNow Text Expander Pro",
  "version": "2.2",
  "description": "Professional Text Expander with ServiceNow productivity features: direct image attachments and URL linkifier.",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "clipboardRead"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://*.service-now.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ServiceNow Expander",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "128": "icon.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/loader.js"],
      "run_at": "document_end",
      "all_frames": true,
      "match_about_blank": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/shared/*.js",
        "src/content/*.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}